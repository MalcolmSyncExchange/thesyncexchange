{
  "name": "the-sync-exchange",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "bash scripts/build-safe.sh",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "node scripts/prepare-typecheck.mjs && tsc --noEmit",
    "validate:env": "node scripts/validate-env.mjs",
    "verify:supabase": "node scripts/diagnose-supabase-project.mjs",
    "create:admin": "node scripts/create-admin.mjs",
    "seed:qa-accounts": "node scripts/seed-test-accounts.mjs",
    "test:buyer-onboarding": "node --test --experimental-strip-types tests/buyer-onboarding.test.mjs tests/onboarding-completion.test.mjs",
    "verify:buyer-onboarding": "node scripts/verify-buyer-onboarding-http.mjs",
    "verify:routes": "zsh scripts/verify-routes.sh",
    "verify:smoke": "zsh scripts/verify-routes.sh",
    "verify:roles": "zsh scripts/verify-role-flows.sh",
    "e2e:install": "npx playwright install chromium",
    "e2e": "npx playwright test",
    "e2e:one": "npx playwright test e2e/marketplace-happy-path.spec.mjs",
    "chrome:local": "bash scripts/open-local-chrome.sh",
    "setup:storage": "node scripts/setup-supabase-storage.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.441.0",
    "next": "^14.2.15",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "stripe": "^16.8.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.6.2"
  }
